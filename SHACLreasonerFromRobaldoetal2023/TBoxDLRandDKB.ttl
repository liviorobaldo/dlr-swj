        rdfs:range   xsd:string .

[ rdf:type          :InferenceRule;
  :has-sparql-code  "CONSTRUCT{?s rdf:type ?o}\n\t\t\t\t\t\tWHERE{?e :not|^:not ?ne. \n\t\t\t\t\t\t\t  BIND(IF(EXISTS{?e rdf:type :Rexist},Triple(?ne,rdf:type,:Rexist), IF(EXISTS{<<?e rdf:type :Rexist>> rdf:type :false},?ne,?s))AS ?s)\n\t\t\t\t\t\t\t  FILTER(BOUND(?s))BIND(IF(isTriple(?s), :false, :Rexist) AS ?o)}"
