[ rdf:type          :InferenceRule;
  :has-sparql-code  "CONSTRUCT{?I1 :intersects ?I2. ?I2 :intersects ?I1}\n\t\t\t\t\t\tWHERE{{?I1 :includes ?I2}UNION{?I1 :includes ?i. ?I2 time:hasBeginning|time:hasEnd ?i}}"
] .

