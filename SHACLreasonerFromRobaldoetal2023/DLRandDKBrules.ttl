			[sh:prefix"";sh:namespace"https://w3id.org/ontology/dlr#"^^xsd:anyURI]];
			sh:construct """CONSTRUCT{$this :intersects ?I2. ?I2 :intersects $this}
						WHERE{{$this :includes ?I2}UNION{$this :includes ?i. ?I2 time:hasBeginning|time:hasEnd ?i}}"""];
sh:targetSubjectsOf :includes.

:rule5 rdf:type sh:NodeShape;
	sh:rule[rdf:type sh:SPARQLRule;
		sh:prefixes[sh:declare
			[sh:prefix"xsd";sh:namespace"http://www.w3.org/2001/XMLSchema#"^^xsd:anyURI],
