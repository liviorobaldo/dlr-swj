			[sh:prefix"";sh:namespace"https://w3id.org/ontology/dlr#"^^xsd:anyURI]];
			sh:construct """CONSTRUCT{$this :includes ?sI}
						WHERE{{$this time:hasBeginning/rdf:type :minusInfinity}UNION
							  {$this time:hasBeginning*/time:inXSDDateTime ?bI. ?sI time:hasBeginning*/time:inXSDDateTime ?bsI. FILTER(?bI<=?bsI)}
							  {$this time:hasEnd/rdf:type :plusInfinity}UNION
							  {$this time:hasEnd*/time:inXSDDateTime ?eI. ?sI time:hasEnd*/time:inXSDDateTime ?esI. FILTER(?esI<=?eI)}}"""];
sh:targetClass time:Interval.

