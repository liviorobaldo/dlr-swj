			sh:construct """CONSTRUCT{?s rdf:type ?o}
						WHERE{$this :not|^:not ?ne. 
							  BIND(IF(EXISTS{$this rdf:type :Rexist},Triple(?ne,rdf:type,:Rexist), IF(EXISTS{<<$this rdf:type :Rexist>> rdf:type :false},?ne,?s))AS ?s)
