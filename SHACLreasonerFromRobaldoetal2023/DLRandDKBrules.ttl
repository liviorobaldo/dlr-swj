			sh:construct """CONSTRUCT{?el rdf:type :Rexist. ?el :has-time ?t1. ?el rdf:type :Keep. ?el :has-agent ?x. ?el :has-object $this.  ?el :has-object-state :lawful. ?el :has-generating-dkb-rule-id "statements9Formula1"^^xsd:string.} WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. $this rdf:type :Rexist. $this rdf:type :ProcessPersonalData. $this :has-time ?t1. $this :has-agent ?x. $this :has-object ?z. ?en rdf:type :Rexist. ?en rdf:type :BeNecessaryFor. ?en :has-agent $this.  ?en :has-object ?eo. ?eo rdf:type :Obligatory. ?eo :has-agent ?y. BIND(BNode() AS ?el) NOT EXISTS{?elr rdf:type :Rexist. ?elr :has-time ?t1. ?elr rdf:type :Keep. ?elr :has-agent ?x. ?elr :has-object $this.  ?elr :has-object-state :lawful. ?elr :has-generating-dkb-rule-id "statements9Formula1"^^xsd:string.}}"""];
