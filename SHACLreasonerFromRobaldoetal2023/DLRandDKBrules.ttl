			sh:construct """CONSTRUCT{<<?enp rdf:type :A-Permitted>> rdf:type :false. ?enp rdf:type :ProcessPersonalData. ?enp :has-agent ?x. ?enp :has-object ?z. ?enp :has-time ?t1. ?enp :is-based-on ?id. ?enp :checks-exception-in-9-2 ($this ?t1 ?x ?z ?id). ?enp :has-generating-dkb-rule-id "statements19Formula5"^^xsd:string.} WHERE{$this rdf:type :DataSubject. ?z :personaldata-of $this.  ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-agent ?y. ?edp :has-object ?x. ?edp :has-time ?t1. ?z rdf:type :GeneticData. ?id rdf:type :Purpose. ?id :is-identification-of $this.  BIND(BNode() AS ?enp) NOT EXISTS{<<?enpr rdf:type :A-Permitted>> rdf:type :false. ?enpr rdf:type :ProcessPersonalData. ?enpr :has-agent ?x. ?enpr :has-object ?z. ?enpr :has-time ?t1. ?enpr :is-based-on ?id. ?enpr :checks-exception-in-9-2 ($this ?t1 ?x ?z ?id). ?enpr :has-generating-dkb-rule-id "statements19Formula5"^^xsd:string.}}"""];
