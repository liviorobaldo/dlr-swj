@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


####################################################################################################################################################################
# Description:
# This example includes an achievement obligation (in (1)) and a factual statement (in (2)). The latter complies with the former, and this is correctly inferred.
# (1) John is obliged to submit the report by 5:00pm (of 1/1/2025, UTC time zone).
# (2) John submitted the report at 3:34pm (of 1/1/2025, UTC time zone).
#-------------------------------------------------------------------------------------------------------------------------------------------------------------------

####################################################################################################################################################################

####################################################################################################################################################################
# Input facts:
####################################################################################################################################################################

#John is obliged to submit the report by 5:00pm (of 1/1/2025, UTC time zone).
:esjo rdf:type :A-Obligatory, :Submit; :has-agent :John; :has-object :report; 
:has-time [a time:Interval; time:hasBeginning [a :minusInfinity]; time:hasEnd [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]].

#John submitted the report at 3:34pm (of 1/1/2025, UTC time zone).
:esj rdf:type :Rexist, :Submit; :has-agent :John; :has-object :report; :has-time [time:inXSDDateTime "2025-01-01T15:34:00Z"^^xsd:dateTime].
