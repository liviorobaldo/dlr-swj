@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


#######################################################################################################################################################################
# Description:
#----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# Article 5(1)(a) of the GDPR states that the processing of personal data must be lawful (as well as fair and transparent, although here we focus solely on lawfulness).
# Article 6(1)(a) of the GDPR states that processing is lawful if the data subject has given consent.
#   => Unless the data subject is under the age of 16; in that case (pursuant to Article 8(1)), the data subject's consent is invalid.
#       => Unless the Member State has set a lower age of consent; if the data subject's age is equal to or above this lower threshold, their consent is valid.
# Article 8(1) further states that if the holder of parental responsibility for a minor gives consent, then the processing is lawful.
# The SPARQL rules implementing the GDPR provisions described above are shown below. A set of sample facts that trigger these obligations and their exceptions is
# also included. Readers are invited to comment or uncomment these facts, rerun the code, and verify that the correct inferences are consistently produced.
#######################################################################################################################################################################

#######################################################################################################################################################################
# Input facts:
#######################################################################################################################################################################

#John is a data processor appointed by Bill, who is the data controller of Jack's personal data, from 5 p.m. to 6 p.m. UTC on 1 January 2025.
:John rdf:type :Processor. :Jack rdf:type :DataSubject. :Bill :controller-of :JackPD. :JackPD :personaldata-of :Jack.
[rdf:type :Rexist,:Nominates; :has-time :t1; :has-agent :Bill; :has-object :John].
:t1 time:hasBeginning [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]; time:hasEnd [time:inXSDDateTime "2025-01-01T18:00:00Z"^^xsd:dateTime].

#John processes Jack's personal data for marketing purposes from 5 p.m. to 6 p.m. UTC on 1 January 2025.
[rdf:type :Rexist,:ProcessPersonalData; :has-time :t1; :has-agent :John; :has-object :JackPD; :is-based-on :marketing]. :marketing rdf:type :Purpose.

#Jack gave his consent for the processing of his personal data at 4:00 p.m. UTC on 1 January 2025.
:egcj rdf:type :Rexist,:Give; :has-agent :Jack; :has-object :c; :has-time [time:inXSDDateTime "2025-01-01T16:00:00Z"^^xsd:dateTime]. :c :is-consent-for :marketing.

#Jack is 15 years old.
:Jack :has-age 15.

#Jack is from Spain, where the minimum age for a minor to give valid consent for data processing is 14 years. This is established by Article 7.1 of
#Organic Law 3/2018 on the Protection of Personal Data and Guarantee of Digital Rights (LOPDGDD),
#see https://en.wikipedia.org/wiki/Organic_Law_on_Protection_of_Personal_Data_and_Guarantee_of_Digital_Rights
#:Jack :has-member-state :Spain. :Spain :has-minimal-age-for-consent 14. 

#Jack's father, who holds parental responsibility for Jack, gave his consent for the processing of Jack's personal data at 4:00 p.m. UTC on 1 January 2025.
:egcfj rdf:type :Rexist,:Give; :has-agent :FatherOfJack; :has-object :cfoj; :has-time [time:inXSDDateTime "2025-01-01T16:00:00Z"^^xsd:dateTime].
:FatherOfJack :is-holder-of-parental-responsibility :Jack. :cfoj :is-consent-for :marketing.







#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# The following rule implements the GDPR norms mentioned above.
# NB: these rules are *copied* from the file DKBrules.ttl. We avoid loading the entire D-KB, as the state of affairs above would otherwise trigger many additional
# obligations, prohibitions, and permissions. Here, we are only interested in checking compliance with the achievement obligation triggered by the rule below.


#D-KB ID: statements1Formula1 (gdprC2A5P1p1ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), then ?x is obliged to keep the processing lawful, fair, and transparent throughout the entire interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements1Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?el rdf:type :M-Obligatory. ?el :has-time ?t1. ?el rdf:type :Keep. ?el :has-agent ?x. ?el :has-object ?ep. ?el :has-object-state :lawful. ?ef rdf:type :M-Obligatory. ?ef :has-time ?t1. ?ef rdf:type :Keep. ?ef :has-agent ?x. ?ef :has-object ?ep. ?ef :has-object-state :fair. ?et rdf:type :M-Obligatory. ?et :has-time ?t1. ?et rdf:type :Keep. ?et :has-agent ?x. ?et :has-object ?ep. ?et :has-object-state :transparent. ?ef :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?el :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?et :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. BIND(BNode() AS ?ef) BIND(BNode() AS ?el) BIND(BNode() AS ?et) NOT EXISTS{?elr rdf:type :M-Obligatory. ?elr :has-time ?t1. ?elr rdf:type :Keep. ?elr :has-agent ?x. ?elr :has-object ?ep. ?elr :has-object-state :lawful. ?efr rdf:type :M-Obligatory. ?efr :has-time ?t1. ?efr rdf:type :Keep. ?efr :has-agent ?x. ?efr :has-object ?ep. ?efr :has-object-state :fair. ?etr rdf:type :M-Obligatory. ?etr :has-time ?t1. ?etr rdf:type :Keep. ?etr :has-agent ?x. ?etr :has-object ?ep. ?etr :has-object-state :transparent. ?efr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?elr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?etr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements7Formula1 (gdprC2A6P1p1ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), and ?w has given consent to the processing at any time before ?t1, then the processing is lawful (represented as "?x keeps the processing lawful throughout ?t1"). However, if the exception in Article 8(1) applies (i.e., if the data subject is a minor), lawfulness cannot be inferred.
[rdf:type :InferenceRule; :has-dkb-id "statements7Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?el rdf:type :Rexist. ?el rdf:type :Keep. ?el :has-time ?t1. ?el :has-agent ?x. ?el :has-object ?ep. ?el :has-object-state :lawful. ?el :checks-exception-in-8-1 (?w). ?el :has-generating-dkb-rule-id "statements7Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?egc rdf:type :Rexist. ?egc rdf:type :Give. ?egc :has-agent ?w. ?egc :has-object ?c. ?egc :has-time ?egct. ?egct time:inXSDDateTime ?dtegc. ?c :is-consent-for ?epu. ?t1 time:hasBeginning ?t1b. ?t1b time:inXSDDateTime ?dtbep. FILTER(?dtegc<?dtbep). BIND(BNode() AS ?el) NOT EXISTS{?elr rdf:type :Rexist. ?elr rdf:type :Keep. ?elr :has-time ?t1. ?elr :has-agent ?x. ?elr :has-object ?ep. ?elr :has-object-state :lawful. ?elr :checks-exception-in-8-1 (?w). ?elr :has-generating-dkb-rule-id "statements7Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements17Formula1 (gdprC2A8P1ref)
#DESCRIPTION: This is an exception to the rule in statements17Formula2. If the data subject is under the age of 16, their consent may still be valid, provided that the Member State to which they belong defines a lower minimum age for consent.
[rdf:type :InferenceRule; :has-dkb-id "statements17Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?exx :defeats-on-8-1-ms ?ex. ?exx :has-generating-dkb-rule-id "statements17Formula1"^^xsd:string.}
	WHERE{?ex :checks-exception-in-8-1-ms (?w ?age). ?w :has-member-state/:has-minimal-age-for-consent ?mac. FILTER(?age>=?mac). BIND(BNode() AS ?exx) NOT EXISTS{?exxr :defeats-on-8-1-ms ?ex. ?exxr :has-generating-dkb-rule-id "statements17Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements17Formula2 (gdprC2A8P1ref)
#DESCRIPTION: The exception in Article 8(1) involves verifying whether the data subject is under the age of 16. If so, the lawfulness of processing under Article 6(1)(a) does not apply, unless the exception-on-8-1-ms condition holds. This condition checks the minimum age of consent as defined by the data subject's Member State (previous rule).
[rdf:type :InferenceRule; :has-dkb-id "statements17Formula2"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ex :defeats-on-8-1 ?el. ?ex :checks-exception-in-8-1-ms (?w ?age). ?ex :has-generating-dkb-rule-id "statements17Formula2"^^xsd:string.}
	WHERE{?el :checks-exception-in-8-1 (?w). ?w :has-age ?age. FILTER(?age<16). BIND(BNode() AS ?ex) NOT EXISTS{?exr :defeats-on-8-1 ?el. ?exr :checks-exception-in-8-1-ms (?w ?age). ?exr :has-generating-dkb-rule-id "statements17Formula2"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements17Formula3 (gdprC2A8P1ref)
#DESCRIPTION: If the holder of parental responsibility for the data subject gives consent to the processing of the data subject's personal data, then the processing is lawful without exception.
[rdf:type :InferenceRule; :has-dkb-id "statements17Formula3"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?el rdf:type :Rexist. ?el :has-time ?t1. ?el rdf:type :Keep. ?el :has-agent ?x. ?el :has-object ?ep. ?el :has-object-state :lawful. ?el :has-generating-dkb-rule-id "statements17Formula3"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?egc rdf:type :Rexist. ?egc rdf:type :Give. ?egc :has-agent ?h. ?h :is-holder-of-parental-responsibility ?w. ?egc :has-object ?c. ?egc :has-time ?egct. ?egct time:inXSDDateTime ?dtegc. ?c :is-consent-for ?epu. ?t1 time:hasBeginning ?t1b. ?t1b time:inXSDDateTime ?dtbep. FILTER(?dtegc<?dtbep). BIND(BNode() AS ?el) NOT EXISTS{?elr rdf:type :Rexist. ?elr :has-time ?t1. ?elr rdf:type :Keep. ?elr :has-agent ?x. ?elr :has-object ?ep. ?elr :has-object-state :lawful. ?elr :has-generating-dkb-rule-id "statements17Formula3"^^xsd:string.}}"""^^xsd:string].