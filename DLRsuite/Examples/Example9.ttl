@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


#######################################################################################################################################################################
# Description:
#----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# This example includes a rule, taken from the D-KB, implementing Article 11(2) of the GDPR. It states that if identification of the data subject is not required for 
# the purposes of the processing, and the data controller is unable to identify the data subject, then the controller is obliged to inform the data subject that they 
# are unable to identify them. In addition to this rule, the following facts are encoded:
# (1) John is a data processor appointed by Bill, the data controller for Jack's personal data. John processes Jack's personal data for marketing purposes from 
# 	  5pm to 6pm UTC on 1 January 2025. However, identifying Jack is not necessary for these purposes.
# (2) Bill demonstrates that he is indeed unable to identify Jack.
# (3) Bill informs Jack at 1am UTC on 2 January 2025 that he is unable to identify him.
# It is inferred that (3) complies with Article 11(2) of the GDPR.
#######################################################################################################################################################################

#######################################################################################################################################################################
# Input facts:
#######################################################################################################################################################################

#John is a data processor appointed by Bill, the data controller for Jack's personal data.
:John rdf:type :Processor. :Jack rdf:type :DataSubject. :JackPD :personaldata-of :Jack. :Bill :controller-of :JackPD.
[rdf:type :Rexist,:Nominates; :has-time :t1; :has-agent :Bill; :has-object :John].

#John processes Jack's personal data for marketing purposes from 5pm to 6pm UTC on 1 January 2025.
[rdf:type :Rexist,:ProcessPersonalData; :has-time :t1; :has-agent :John; :has-object :JackPD; :is-based-on :marketing]. :marketing rdf:type :Purpose.
:t1 time:hasBeginning [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]; time:hasEnd [time:inXSDDateTime "2025-01-01T18:00:00Z"^^xsd:dateTime].

#However, identifying Jack is not necessary for these purposes.
:enn rdf:type :Rexist; :not :en. :en rdf:type :BeNecessaryFor; :has-time :t1; :has-agent :eid; :has-object :marketing.
:eid rdf:type :Identify; :has-agent :Bill; :has-object :Jack.

#Bill demonstrates that he is indeed unable to identify Jack.
[rdf:type :Rexist,:Demonstrate; :has-agent :Bill; :has-time :t1; :has-object :ena]. :ena :not :ea. :ea rdf:type :BeAbleTo; :has-agent :Bill; :has-object :eid; :has-time :t1.

#Bill informs Jack at 1am UTC on 2 January 2025 that he is unable to identify him.
[rdf:type :Rexist,:Communicate; :has-agent :Bill; :has-recipient :Jack; :has-object :ena; :has-time [time:inXSDDateTime "2025-01-02T01:00:00Z"^^xsd:dateTime]].


#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# The following rules implement the specific norm from Article 11(2) of the GDPR mentioned above. If the data processor finds that some personal data is inaccurate, 
# they are obliged to delete or rectify the data "without delay". NB. this rule is *COPIED* from the file DKBrules.ttl. The entire D-KB is not included, as the 
# state of affairs above would otherwise trigger many additional obligations, prohibitions, and permissions. The focus here is solely on checking compliance with 
# the achievement obligation triggered by the facts above.

#D-KB ID: statements31Formula1 (gdprC2A11P2ref)
#DESCRIPTION: If ?x is processing ?w’s personal data during the interval ?t1 (with the data controlled by ?y, who appointed ?x), but the identification of ?w is no longer necessary for the processing and ?y demonstrates that they are unable to identify ?w, then ?y is obliged to communicate this to ?w.
[rdf:type :InferenceRule; :has-dkb-id "statements31Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ec rdf:type :A-Obligatory. ?ec rdf:type :Communicate. ?ec :has-agent ?y. ?ec :has-object ?ena. ?ec :has-recipient ?w. ?ec :has-time ?t2. ?ec :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?enn rdf:type :Rexist. ?enn :not ?en. ?en rdf:type :BeNecessaryFor. ?en :has-time ?t1. ?en :has-agent ?eid. ?en :has-object ?epu. ?eid rdf:type :Identify. ?eid :has-object ?w. ?ed rdf:type :Rexist. ?ed rdf:type :Demonstrate. ?ed :has-time ?t1. ?ed :has-agent ?y. ?ed :has-object ?ena. ?ena :not ?ea. ?ea rdf:type :BeAbleTo. ?ea :has-time ?t1. ?ea :has-agent ?y. ?ea :has-object ?eid. ?t2 :is-without-delay ?t1. BIND(BNode() AS ?ec) NOT EXISTS{?ecr rdf:type :A-Obligatory. ?ecr rdf:type :Communicate. ?ecr :has-agent ?y. ?ecr :has-object ?ena. ?ecr :has-recipient ?w. ?ecr :has-time ?t2. ?ecr :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string.}}"""^^xsd:string].

