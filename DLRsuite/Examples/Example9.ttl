@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


#######################################################################################################################################################################
# Description:
# This example includes a rule, copied from the D-KB, that implements Article 11(2) of the GDPR: if identifying the data subject is not necessary for the purpose of
# the processing, and the data controller is not able to identify the data subject, then the controller is obliged to inform the data subject that he or she is
# unable to identify them.
# In addition to this rule, the following facts are encoded:
# (1) John is a data processor, appointed by Bill, the data controller for Jack's personal data. John processes Jack's personal data for marketing purposes from 5pm
#     to 6pm UTC on January 1, 2025. However, identifying Jack is not necessary for these purposes.
# (2) Bill demonstrates that he is indeed unable to identify Jack.
# (3) Bill informs Jack that he is unable to identify him at 1am UTC on January 2, 2025.
# It is inferred that (3) complies with Article 11(2) of the GDPR.
#----------------------------------------------------------------------------------------------------------------------------------------------------------------------

#######################################################################################################################################################################

#######################################################################################################################################################################
# Input facts:
#######################################################################################################################################################################

#John is a data processor, appointed by Bill, who is the data controller of Jack's personal data.
:John rdf:type :Processor. :Jack rdf:type :DataSubject. :JackPD :personaldata-of :Jack. :Bill :controller-of :JackPD.
[rdf:type :Rexist,:Nominates; :has-time :t1; :has-agent :Bill; :has-object :John].

#John processes Jack's personal data for marketing purposes from 5pm to 6pm UTC on January 1, 2025.
[rdf:type :Rexist,:ProcessPersonalData; :has-time :t1; :has-agent :John; :has-object :JackPD; :is-based-on :marketing]. :marketing rdf:type :Purpose.
:t1 time:hasBeginning [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]; time:hasEnd [time:inXSDDateTime "2025-01-01T18:00:00Z"^^xsd:dateTime].

#However, it is not necessary for Bill to identify Jack for these purposes.
:enn rdf:type :Rexist; :not :en. :en rdf:type :BeNecessaryFor; :has-time :t1; :has-agent :eid; :has-object :marketing.
:eid rdf:type :Identify; :has-agent :Bill; :has-object :Jack.

#Moreover, Bill demonstrates that he is not able to identify Jack.
[rdf:type :Rexist,:Demonstrate; :has-agent :Bill; :has-time :t1; :has-object :ena]. :ena :not :ea. :ea rdf:type :BeAbleTo; :has-agent :Bill; :has-object :eid; :has-time :t1.

#Bill communicates to Jack that he is unable to identify him at 1am UTC on January 2, 2025.
[rdf:type :Rexist,:Communicate; :has-agent :Bill; :has-recipient :Jack; :has-object :ena; :has-time [time:inXSDDateTime "2025-01-02T01:00:00Z"^^xsd:dateTime]].


#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------
#The following rule implements the specific norm from Article 11(2) of the GDPR mentioned above: if identifying the data subject is not necessary for the purposes of 
#the processing, and the data controller is not able to identify the data subject, then the data controller is obliged to communicate to the data subject that he is 
#unable to identify him/her.

#NB. this rule is *COPIED* from the file DKBrules.ttl. We avoid uploading the entire D-KB, as the state of affairs above would otherwise trigger many additional
#obligations, prohibitions, and permissions. Here we are only interested in checking compliance with the achievement obligation triggered by the rule below.

#D-KB ID: statements31Formula1 (gdprC2A11P2ref)
#DESCRIPTION: If ?x is processing ?w’s personal data during the interval ?t1 (with the data controlled by ?y, who appointed ?x), but the identification of ?w is no longer necessary for the processing and ?y demonstrates that they are unable to identify ?w, then ?y is obliged to communicate this to ?w.
[rdf:type :InferenceRule; :has-dkb-id "statements31Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ec rdf:type :A-Obligatory. ?ec rdf:type :Communicate. ?ec :has-agent ?y. ?ec :has-object ?ena. ?ec :has-recipient ?w. ?ec :has-time ?t2. ?t2 rdf:type time:Interval. ?t2 :IsWithoutDelayWrt ?t1. ?ec :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string. ?t2 :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?enn rdf:type :Rexist. ?enn :not ?en. ?en rdf:type :BeNecessaryFor. ?en :has-time ?t1. ?en :has-agent ?eid. ?en :has-object ?epu. ?eid rdf:type :Identify. ?eid :has-object ?w. ?ed rdf:type :Rexist. ?ed rdf:type :Demonstrate. ?ed :has-time ?t1. ?ed :has-agent ?y. ?ed :has-object ?ena. ?ena :not ?ea. ?ea rdf:type :BeAbleTo. ?ea :has-time ?t1. ?ea :has-agent ?y. ?ea :has-object ?eid. BIND(BNode() AS ?ec) BIND(BNode() AS ?t2) NOT EXISTS{?ecr rdf:type :A-Obligatory. ?ecr rdf:type :Communicate. ?ecr :has-agent ?y. ?ecr :has-object ?ena. ?ecr :has-recipient ?w. ?ecr :has-time ?t2r. ?t2r rdf:type time:Interval. ?t2r :IsWithoutDelayWrt ?t1. ?ecr :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string. ?t2r :has-generating-dkb-rule-id "statements31Formula1"^^xsd:string.}}"""^^xsd:string].

