@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


####################################################################################################################################################################
# Description:
#-------------------------------------------------------------------------------------------------------------------------------------------------------------------
# This example includes the following norms, all but one of which establish exceptions to other norms or to prior exceptions:
# (1) MAIN OBLIGATION: Anyone who is prescribed a medicine by a GP is obliged to pay the cost of the medicine.
# (2) EXCEPTION TO (1): If the patient is disabled, they are exempt from paying the cost of the medicine.
# (3) EXCEPTION TO (1): If the cost of the medicine exceed £50, the patient is exempt from paying it.
# (4) EXCEPTION TO (3): The exemption in (3) does not apply if the patient is a non-UK national; non-UK nationals must pay the full cost even if it exceeds £50.
# (5) EXCEPTION TO (4): However, the exception in (4) does not apply to refugees, who are treated as UK nationals (the exemption in (3) applies to them as well).
#
# The input facts are reported below. These are asserted with respect to two individuals: John and Pedro. The user is invited to comment/uncomment the facts 
# referring to these two individuals (e.g., disability status, UK nationality, etc.) and to verify that the correct inferences are derived under all possible 
# combinations.
####################################################################################################################################################################

####################################################################################################################################################################
# Input facts:
####################################################################################################################################################################

#Anyone who is prescribed a medicine by a GP is obliged to pay the cost of the medicine.
#...unless the exceptions from (2) or (3) above (or both) apply.
:checks-exception-in-2 rdfs:subPropertyOf :checks-exception.
:checks-exception-in-3 rdfs:subPropertyOf :checks-exception.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?eo rdf:type :Pay,:A-Obligatory; :has-agent ?pa; :has-object ?cm; :checks-exception-in-2 (?pa); :checks-exception-in-3 (?cm ?pa)}
						WHERE{?eg rdf:type :Rexist,:Prescribe; :has-agent ?g; :has-object ?m; :has-recipient ?pa. 
							  ?g rdf:type :GP. ?m rdf:type :Medicine. ?m :has-cost ?cm. BIND(BNode() AS ?eo)
							  NOT EXISTS{?eor rdf:type :Pay,:A-Obligatory; :has-agent ?pa; :has-object ?cm}}"""^^xsd:string].

#Exception from (2):
#...unless the patient is disabled, in which case they are exempt from paying the cost of the medicine.
:defeats-on-2 rdfs:subPropertyOf :defeats.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?ed :defeats-on-2 ?eo}
						WHERE{?eo :checks-exception-in-2 (?pa). ?pa rdf:type :Disabled.
							  BIND(BNode()AS ?ed) NOT EXISTS{?edr :defeats-on-2 ?eo}}"""^^xsd:string].

#Exception from (3):
#...unless the cost of the medicine exceeds £50, in which case the patient is exempt from paying them.
#	...unless the exception from (4) above apply, in which case the patient is *not* exempt.
:defeats-on-3 rdfs:subPropertyOf :defeats.
:checks-exception-in-4 rdfs:subPropertyOf :checks-exception.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?ed :defeats-on-3 ?eo;
								  :checks-exception-in-4 (?pa)}
						WHERE{?eo :checks-exception-in-3 (?cm ?pa). ?cm :has-value-in-pounds ?v. FILTER(?v>50) BIND(BNode()AS ?ed) 
							  NOT EXISTS{?edr :defeats-on-3 ?eo}}"""^^xsd:string].

#Exception from (4):
#...in particular, the exemption does not apply if the patient is a non-UK national; non-UK nationals must pay the full cost of the medicine even if they exceed £50.
#...unless the exception from (5) above apply, in which case the patient is exempt.
:defeats-on-4 rdfs:subPropertyOf :defeats.
:checks-exception-in-5 rdfs:subPropertyOf :checks-exception.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?ed :defeats-on-4 ?e; :checks-exception-in-5 (?pa)}
						WHERE{?e :checks-exception-in-4 (?pa). ?pa a :NonUKNational.
							  BIND(BNode()AS ?ed) NOT EXISTS{?edr :defeats-on-4 ?e}}"""^^xsd:string].

#Exception from (5):
#...But this exception to the exemption applies only if the non-UK national is not a refugee;
#if the patient is a refugee, s/he is considered a UK national and is therefore exempt.
:defeats-on-5 rdfs:subPropertyOf :defeats.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?ed :defeats-on-5 ?e}
						WHERE{?e :checks-exception-in-5 (?pa). ?pa a :Refugee.
							  BIND(BNode()AS ?ed) NOT EXISTS{?edr :defeats-on-5 ?e}}"""^^xsd:string].


####################################################################################################################################################################
# comment/uncomment the facts below to produce different derivations using the rules above.
####################################################################################################################################################################

#:gp, a GP, prescribes John a medicine :m.
[rdf:type :Rexist,:Prescribe; :has-agent :gp; :has-object :m; :has-recipient :John]. 
:gp rdf:type :GP. :m rdf:type :Medicine.

#:gp also prescribes the same medicine to Pedro.
[rdf:type :Rexist,:Prescribe; :has-agent :gp; :has-object :m; :has-recipient :Pedro]. 

#The medicine :m costs £100 (change the cost as you wish).
:m :has-cost :cm. :cm :has-value-in-pounds 100.

#John is disabled.
#:John rdf:type :Disabled.

#John is non-UK national.
#:John rdf:type :NonUKNational.

#John is a refugee.
#:John rdf:type :Refugee.

#John pays the prescription's charges.
[rdf:type :Rexist,:Pay; :has-agent :John; :has-object :cm].

#Pedro is disabled.
#:Pedro rdf:type :Disabled.

#Pedro is non-UK national.
:Pedro rdf:type :NonUKNational.

#Pedro is a refugee.
#:Pedro rdf:type :Refugee.

#Pedro pays the prescription's charges.
[rdf:type :Rexist,:Pay; :has-agent :Pedro; :has-object :cm].



