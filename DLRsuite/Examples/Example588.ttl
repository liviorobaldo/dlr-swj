@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


#######################################################################################################################################################################
# Input facts:
#######################################################################################################################################################################

#John is a data processor, appointed by Bill, who is the data controller of Jack's personal data.
:John rdf:type :Processor. :Jack rdf:type :DataSubject. :JackPD :personaldata-of :Jack. :Bill :controller-of :JackPD.
[rdf:type :Rexist,:Nominates; :has-time :t1; :has-agent :Bill; :has-object :John].

#John processes Jack's personal data from 5pm to 6pm UTC on January 1, 2025.
:ep rdf:type :Rexist,:ProcessPersonalData; :has-time :t1; :has-agent :John; :has-object :JackPD.
:t1 time:hasBeginning [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]; time:hasEnd [time:inXSDDateTime "2025-01-01T18:00:00Z"^^xsd:dateTime].

#The processing :ep is based on the purpose :epu
:ep :is-based-on :epu.
:epu a :Purpose.



[ rdf:type                     :Active , :Eventuality , :Obligatory , :M-Obligatory , :ControlledOrAuthorized;
  :has-generating-dkb-rule-id  "statements29Formula1";
  :has-object                  :ep_0;
  :has-time                    :t1
] .

:eiscoa_0  rdf:type  :Active , :Eventuality , :Rexist , :ControlledOrAuthorized;
        :has-object  :ep_0;
        :has-time    :t_that_includes_t1 .
		
		
:t1 rdf:type time:Interval; time:hasBeginning :t1b; time:hasEnd :t1e.
:t1b time:inXSDDateTime "2026-01-01T17:00:00Z"^^xsd:dateTime.
:t1e time:inXSDDateTime "2026-01-01T18:00:00Z"^^xsd:dateTime.
:t_that_includes_t1 rdf:type time:Interval; time:hasBeginning :t_that_includes_t1b; time:hasEnd :t_that_includes_t1e.
:t_that_includes_t1b time:inXSDDateTime "2026-01-01T16:00:00Z"^^xsd:dateTime.  
:t_that_includes_t1e time:inXSDDateTime "2026-01-01T19:00:00Z"^^xsd:dateTime.


		
#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# QUI SOTTO DEVI METTERE LE *SINGOLE* D-KB RULES CHE VUOI TESTARE, DAL FILE DKBrules.ttl


#D-KB ID: statements84Formula1 (gdprC3S3A17P1ref)
#DESCRIPTION: If ?x processes ?w's personal data during interval ?t1 (where the data are controlled by ?y, who has appointed ?x as the processor), and the data subject requests, at time ?t1, to delete some of his personal data, the controller is obliged to complete them without undue delay.
[rdf:type :InferenceRule; :has-dkb-id "statements84Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?eo rdf:type :A-Obligatory. ?eo rdf:type :Delete. ?eo :has-agent ?x. ?eo :has-object ?z. ?eo :has-time ?t2. ?t2 rdf:type time:Interval. ?t2 :IsWithoutDelayWrt ?t1. ?eo :checks-exception-in-11-2 (?y ?w ?t1 ?epu). ?eo :has-generating-dkb-rule-id "statements84Formula1"^^xsd:string. ?t2 :has-generating-dkb-rule-id "statements84Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?er rdf:type :Rexist. ?er rdf:type :Request. ?er :has-agent ?w. ?er :has-object ?ec. ?ec rdf:type :Delete. ?ec :has-agent ?x. ?ec :has-object ?z. BIND(BNode() AS ?eo) BIND(BNode() AS ?t2) NOT EXISTS{?eor rdf:type :A-Obligatory. ?eor rdf:type :Delete. ?eor :has-agent ?x. ?eor :has-object ?z. ?eor :has-time ?t2r. ?t2r rdf:type time:Interval. ?t2r :IsWithoutDelayWrt ?t1. ?eor :checks-exception-in-11-2 (?y ?w ?t1 ?epu). ?eor :has-generating-dkb-rule-id "statements84Formula1"^^xsd:string. ?t2r :has-generating-dkb-rule-id "statements84Formula1"^^xsd:string.}}"""^^xsd:string].
