@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


##################################################################################################################################################################
# Description:
# This example includes a norm stating that anyone who parks in the city center is prohibited from parking for more than one hour (in (1)). The norm takes the 
# start of the parking interval and adds one hour to determine the end instant. The example also includes a factual statement indicating that John parked in the 
# city center from 2:00pm to 4:00pm (in (2)), thereby violating the maintenance prohibition. The violation is correctly inferred.
# (1) Whoever park in the city center is prohibited to park for more than one hour.
# (2) John parks in the city center from 2:00pm to 4:00pm
#-----------------------------------------------------------------------------------------------------------------------------------------------------------------
##################################################################################################################################################################

##################################################################################################################################################################
# Input facts:
##################################################################################################################################################################

#Whoever park in the city center is prohibited to park for more than one hour.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{<<?ep rdf:type :M-Permitted>> rdf:type :false. ?ep rdf:type :Park; :has-agent ?a; :has-location :citycenter; :has-time 
								  [rdf:type time:Interval; time:hasBeginning [time:inXSDDateTime ?beg]; time:hasEnd [time:inXSDDateTime ?end]]}
						WHERE{?e rdf:type :Rexist,:Park; :has-agent ?a; :has-location :citycenter; :has-time 
							  [rdf:type time:Interval; time:hasBeginning [time:inXSDDateTime ?beg]].
							  BIND(xsd:dateTime(?beg)+'PT1H'^^xsd:duration AS ?end) BIND(BNode() AS ?ep)
							  NOT EXISTS{<<?epr rdf:type :M-Permitted>> rdf:type :false. ?epr rdf:type :Park; :has-agent ?a; :has-location :citycenter; :has-time 
								  [rdf:type time:Interval; time:hasBeginning [time:inXSDDateTime ?beg]; time:hasEnd [time:inXSDDateTime ?end]]}}"""^^xsd:string].
		
#John parks in the city center from 2:00pm to 4:00pm
:epj rdf:type :Rexist, :Park; :has-agent :John; :has-location :citycenter; :has-time [rdf:type time:Interval;
	time:hasBeginning [time:inXSDDateTime "2025-01-01T14:00:00Z"^^xsd:dateTime]; 
	time:hasEnd [time:inXSDDateTime "2025-01-01T16:00:00Z"^^xsd:dateTime]].

