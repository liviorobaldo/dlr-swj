@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .

#######################################################################################################################################################################
# Description:
#----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# This example includes a rule copied from the D-KB that implements a specific norm from Article 5(1)(d) of the GDPR:
# if the data processor finds that some personal data is inaccurate, they are obliged to delete or rectify the data "without delay".
# In this context, "without delay" is interpreted as "within 24 hours"; this interpretation is enforced by a dedicated rule stored in the file DKBTBox.ttl.
# In addition to this rule, the following facts are encoded:
# (1) John is a data processor, appointed by Bill, the data controller of Jack's personal data. John processes Jack's personal data for marketing purposes from 5pm
#     to 6pm UTC on 1.1.2025. 
# (2) Jack's personal data is inaccurate.
# (3) John deletes Jack's inaccurate personal data at 1am UTC on 2.1.2025.
# It is inferred that (3) complies with Article 5(1)(d) of the GDPR under the above interpretation of "without delay".
#######################################################################################################################################################################

#######################################################################################################################################################################
# Input facts:
#######################################################################################################################################################################

#John is a data processor, appointed by Bill, the data controller of Jack's personal data.
:John rdf:type :Processor. :Jack rdf:type :DataSubject. :JackPD :personaldata-of :Jack. :Bill :controller-of :JackPD.
[rdf:type :Rexist,:Nominates; :has-time :t1; :has-agent :Bill; :has-object :John].

#John processes Jack's personal data for marketing purposes from 5pm to 6pm UTC on 1.1.2025.
[rdf:type :Rexist,:ProcessPersonalData; :has-time :t1; :has-agent :John; :has-object :JackPD; :is-based-on :marketing]. :marketing rdf:type :Purpose.
:t1 time:hasBeginning [time:inXSDDateTime "2025-01-01T17:00:00Z"^^xsd:dateTime]; time:hasEnd [time:inXSDDateTime "2025-01-01T18:00:00Z"^^xsd:dateTime].

#Jack's personal data are inaccurate.
:JackPD rdf:type :inaccurate.

#John deletes Jack's inaccurate personal data at 1am UTC on 2.1.2025.
[rdf:type :Rexist,:Delete; :has-agent :John; :has-object :JackPD; :has-time [time:inXSDDateTime "2025-01-02T01:00:00Z"^^xsd:dateTime]].



#-----------------------------------------------------------------------------------------------------------------------------------------------------------------------
# The following rules implement the specific norm from Article 5(1)(d) of the GDPR mentioned above. If the data processor finds that some personal data is inaccurate, 
# they are obliged to delete or rectify the data "without delay". NB. these rules are *COPIED* from the file DKBrules.ttl. The entire D-KB is not included, as the 
# state of affairs above would otherwise trigger many additional obligations, prohibitions, and permissions. The focus here is solely on checking compliance with 
# the achievement obligation triggered by the facts above.

#D-KB ID: statements4Formula2 (gdprC2A5P1p4ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), but this data is inaccurate, then 
#?x is obliged to delete or rectify the data without delay.
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?eo rdf:type :A-Obligatory. ?eo rdf:type :DeleteOrRectify. ?eo :has-agent ?x. ?eo :has-object ?z. ?eo :has-time ?t2. ?eo :has-generating-dkb-rule-id "statements4Formula2"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp :has-time ?t1. ?edp rdf:type :Nominates. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep :has-time ?t1. ?ep rdf:type :ProcessPersonalData. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?z rdf:type :inaccurate. ?t2 :is-without-delay ?t1. BIND(BNode() AS ?eo) NOT EXISTS{?eor rdf:type :A-Obligatory. ?eor rdf:type :DeleteOrRectify. ?eor :has-agent ?x. ?eor :has-object ?z. ?eor :has-time ?t2. ?eor :has-generating-dkb-rule-id "statements4Formula2"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements4Formula2-disjunction (gdprC2A5P1p4ref)
#DESCRIPTION: The following rules were introduced as a more effective alternative to modelling the predicate "or" from Hobbs' framework. If the action ?e is either 
#Delete or Rectify, then it is also classified as an action of type 'DeleteOrRectify', which is the predicate used in the previous formula.
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?e rdf:type :DeleteOrRectify.}
	WHERE{?e rdf:type :Delete.}"""^^xsd:string].
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?e rdf:type :DeleteOrRectify.}
	WHERE{?e rdf:type :Rectify.}"""^^xsd:string].