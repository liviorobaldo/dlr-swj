@prefix : <https://w3id.org/ontology/dlr#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix time: <http://www.w3.org/2006/time#> .
@base <https://w3id.org/ontology/dlr#> .


#================================================================================================================================================================
# RDF properties for compliance checking inferences.
#================================================================================================================================================================

#Really existing eventualities can comply with obligations, violate non-permissions (i.e., prohibitions), conform to permissions, or really exist even when the 
#normative code explicit specifies that they are not obligatory. The four properties below make these relations explicit.
#NB. The domain of these four properties is always Rexist, but the range cannot always be defined as a class, since in the case of violates and 
#rexists-although-not-obligatory, the relation applies to a non-permission and a non-obligation. To address this, we would either need two SHACL shapes, 
#or to define two classes (e.g., Prohibited and Omitted) and use SPARQL rules to make them equivalent to ¬Permitted and ¬Obligatory.
:complies-with rdf:type rdf:Property; rdfs:domain :Rexist; rdfs:range :Eventuality. #for Obligations
:violates rdf:type rdf:Property; rdfs:domain :Rexist; rdfs:range :Eventuality. #for not-Permissions
:conforms-to rdf:type rdf:Property; rdfs:domain :Rexist; rdfs:range :Eventuality. #for Permissions
:rexists-although-not-obligatory rdf:type rdf:Property; rdfs:domain :Rexist; rdfs:range :Eventuality. #for not-Obligations

#Once all :defeats relations have been established (from the root to the leaves of the exception trees), we determine which obligations are active rather than 
#inactive (processing from the leaves back to the root). Compliance, violations, etc. are then inferred only for active eventualities (see rules below)
:Active rdf:type rdfs:Class. 
:Inactive rdf:type rdfs:Class.
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e a :Active}
						WHERE{{{?e rdf:type ?M}UNION{<<?e rdf:type ?M>> rdf:type :false} ?M rdfs:subClassOf*/rdf:type :Modality}UNION{?e :defeats ?ea}
							  NOT EXISTS{?se :defeats ?e. NOT EXISTS{?se a :Inactive}}}"""^^xsd:string].
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?se a :Inactive}
						WHERE{?e a :Active. ?e :defeats ?se}"""^^xsd:string].


#================================================================================================================================================================
# Compliance with Obligations
#================================================================================================================================================================

# If an active really existing eventuality e is more specific than an active obligation eo (meaning they describe the same action or event, the set of thematic 
# roles of e is a superset of those of eo, and the common thematic roles have identical values), then it is inferred that eo is complied with by e.

#Compliance with achievement obligations:
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :complies-with ?eo}
						WHERE{?eo rdf:type :A-Obligatory,?ET,:Active. ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eo ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eo ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?eo :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?eo :has-time ?vo. ?e :has-time ?v. ?vo :intersects ?v},true,false)))}"""^^xsd:string].

#Compliance with maintenance obligations:									 
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :complies-with ?eo}
						WHERE{?eo rdf:type :M-Obligatory,?ET,:Active. ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eo ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eo ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?eo :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?eo :has-time ?vo. ?e :has-time ?v. ?v :includes ?vo},true,false)))}"""^^xsd:string].


#================================================================================================================================================================
# Real existence (although not obligatory) of not-obligations
#================================================================================================================================================================

#Real existence (although not obligatory) of achievement not-obligations:
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :rexists-although-not-obligatory ?eno}
						WHERE{<<?eno rdf:type :A-Obligatory>> rdf:type :false. ?eno rdf:type ?ET,:Active. 
							  ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eno ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eno ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?eno :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?eno :has-time ?vo. ?e :has-time ?v. ?vo :intersects ?v},true,false)))}"""^^xsd:string].

#Real existence (although not obligatory) of maintenance not-obligations:								 
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :rexists-although-not-obligatory ?eno}
						WHERE{<<?eno rdf:type :M-Obligatory>> rdf:type :false. ?eno rdf:type ?ET,:Active. 
							  ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eno ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?eno ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?eno :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?eno :has-time ?vo. ?e :has-time ?v. ?v :includes ?vo},true,false)))}"""^^xsd:string].


#================================================================================================================================================================
# Conformance of Permissions
#================================================================================================================================================================

#Conformance of achievement permissions:
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :conforms-to ?ep}
						WHERE{?ep rdf:type :A-Permitted,?ET,:Active. ?e rdf:type :Rexist,?ET,:Active.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?ep ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?ep ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?ep :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?ep :has-time ?vo. ?e :has-time ?v. ?vo :intersects ?v},true,false)))}"""^^xsd:string].

#Compliance with maintenance permissions:									 
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :conforms-to ?ep}
						WHERE{?ep rdf:type :M-Permitted,?ET,:Active. ?e rdf:type :Rexist,?ET,:Active.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?ep ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?ep ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?ep :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?ep :has-time ?vo. ?e :has-time ?v. ?v :includes ?vo},true,false)))}"""^^xsd:string].


#================================================================================================================================================================
# Violation of not-permissions (i.e., prohibitions)
#================================================================================================================================================================

#Violations of achievement not-permissions:
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :violates ?enp}
						WHERE{<<?enp rdf:type :A-Permitted>> rdf:type :false. ?enp rdf:type ?ET,:Active. 
							  ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?enp ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?enp ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?enp :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?enp :has-time ?vo. ?e :has-time ?v. ?vo :intersects ?v},true,false)))}"""^^xsd:string].

#Violations of maintenance not-permissions:								 
[rdf:type :InferenceRule;
	:has-sparql-code """CONSTRUCT{?e :violates ?enp}
						WHERE{<<?enp rdf:type :M-Permitted>> rdf:type :false. ?enp rdf:type ?ET,:Active. 
							  ?e rdf:type :Rexist,?ET,:Active. ?ET rdf:type :EventualityType.
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?enp ?tr ?vo. NOT EXISTS{?e ?tr ?v}}
							  NOT EXISTS{?tr rdf:type :ThematicRole. ?enp ?tr ?vo. ?e ?tr ?v. FILTER((?tr!=:has-time)&&(?vo!=?v))}
							  FILTER(IF(NOT EXISTS{?enp :has-time ?vo. ?e :has-time ?v},true,
									 IF(EXISTS{?enp :has-time ?vo. ?e :has-time ?v. ?v :includes ?vo},true,false)))}"""^^xsd:string].






