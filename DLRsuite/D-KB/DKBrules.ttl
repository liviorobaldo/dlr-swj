	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?egc rdf:type :Rexist. ?egc rdf:type :Give. ?egc :has-agent ?w. ?egc :has-object ?c. ?c :is-consent-for ?epu. ?er rdf:type :Rexist. ?er rdf:type :Request. ?er :has-time ?t2. ?er :has-object ?c. ?er :has-recipient ?w. ?er :has-instrument ?wd. ?wd rdf:type :WrittenDeclaration. ?c :is-part-of ?wd. BIND(BNode() AS ?ec) NOT EXISTS{?ecr rdf:type :M-Obligatory. ?ecr :has-time ?t2. ?ecr rdf:type :Keep. ?ecr :has-agent ?x. ?ecr :has-object ?er. ?ecr :has-object-state :clear. ?ecr :has-generating-dkb-rule-id "statements15Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements16Formula1 (gdprC2A7P3ref)
#DESCRIPTION: If  ?x  is processing  ?w's personal data during the interval  ?t1  (and the data is controlled by  ?y, who appointed  ?x), and the data subject gave consent to the purpose ?epu for processing the data, then the data subject shall have the right to withdraw his or her consent at any time.
[rdf:type :InferenceRule; :has-dkb-id "statements16Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ew rdf:type :A-Permitted. ?ew :has-time ?t1. ?ew rdf:type :Withdraw. ?ew :has-agent ?w. ?ew :has-object ?c. ?ew :has-generating-dkb-rule-id "statements16Formula1"^^xsd:string.}
