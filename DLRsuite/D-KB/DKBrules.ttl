#D-KB ID: statements1Formula1 (gdprC2A5P1p1ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), then ?x is obliged to keep the processing lawful, fair, and transparent throughout the entire interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements1Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?el rdf:type :M-Obligatory. ?el :has-time ?t1. ?el rdf:type :Keep. ?el :has-agent ?x. ?el :has-object ?ep. ?el :has-object-state :lawful. ?ef rdf:type :M-Obligatory. ?ef :has-time ?t1. ?ef rdf:type :Keep. ?ef :has-agent ?x. ?ef :has-object ?ep. ?ef :has-object-state :fair. ?et rdf:type :M-Obligatory. ?et :has-time ?t1. ?et rdf:type :Keep. ?et :has-agent ?x. ?et :has-object ?ep. ?et :has-object-state :transparent. ?ef :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?el :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?et :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. BIND(BNode() AS ?ef) BIND(BNode() AS ?el) BIND(BNode() AS ?et) NOT EXISTS{?elr rdf:type :M-Obligatory. ?elr :has-time ?t1. ?elr rdf:type :Keep. ?elr :has-agent ?x. ?elr :has-object ?ep. ?elr :has-object-state :lawful. ?efr rdf:type :M-Obligatory. ?efr :has-time ?t1. ?efr rdf:type :Keep. ?efr :has-agent ?x. ?efr :has-object ?ep. ?efr :has-object-state :fair. ?etr rdf:type :M-Obligatory. ?etr :has-time ?t1. ?etr rdf:type :Keep. ?etr :has-agent ?x. ?etr :has-object ?ep. ?etr :has-object-state :transparent. ?efr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?elr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string. ?etr :has-generating-dkb-rule-id "statements1Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements2Formula1 (gdprC2A5P1p2ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x) and the processing is based on the purpose ?epu, then ?x is obliged to specify this purpose *before* ?t1, to keep it legitimate and explicit throughout the interval ?t1, and to keep the processing compatible with this purpose throughout the interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements2Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?es rdf:type :A-Obligatory. ?es rdf:type :Specify. ?es :has-agent ?x. ?es :has-object ?epuc. ?es :has-time ?t3. ?el rdf:type :M-Obligatory. ?el :has-time ?t2. ?el rdf:type :Keep. ?el :has-agent ?x. ?el :has-object ?epuc. ?el :has-object-state :legitimate. ?ex rdf:type :M-Obligatory. ?ex :has-time ?t2. ?ex rdf:type :Keep. ?ex :has-agent ?x. ?ex :has-object ?epuc. ?ex :has-object-state :explicit. ?ecw rdf:type :M-Obligatory. ?ecw :has-time ?t1. ?ecw rdf:type :Keep. ?ecw :has-agent ?x. ?ecw :has-object ?ep. ?ecw :has-object-state :compatible. ?ecw :has-object-state-with ?epuc. ?ecw :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?ex :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?el :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?es :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?t1 time:hasBeginning/time:inXSDDateTime ?t1b. ?t2 rdf:type time:Interval. ?t2 time:hasBeginning ?t2b. ?t2 time:hasEnd/time:inXSDDateTime ?t2e. FILTER(?t2e<=?t1b). ?ec rdf:type :Rexist. ?ec rdf:type :CollectPersonalData. ?ec :has-time ?t2. ?ec :has-agent ?x. ?ec :has-object ?z. ?epuc rdf:type :Purpose. ?ec :is-based-on ?epuc. ?mi rdf:type time:Instant. ?mi rdf:type :minusInfinity. ?t3 rdf:type time:Interval. ?t3 time:hasBeginning ?mi. ?t3 time:hasEnd ?t2b. BIND(BNode() AS ?ecw) BIND(BNode() AS ?ex) BIND(BNode() AS ?el) BIND(BNode() AS ?es) NOT EXISTS{?esr rdf:type :A-Obligatory. ?esr rdf:type :Specify. ?esr :has-agent ?x. ?esr :has-object ?epuc. ?esr :has-time ?t3. ?elr rdf:type :M-Obligatory. ?elr :has-time ?t2. ?elr rdf:type :Keep. ?elr :has-agent ?x. ?elr :has-object ?epuc. ?elr :has-object-state :legitimate. ?exr rdf:type :M-Obligatory. ?exr :has-time ?t2. ?exr rdf:type :Keep. ?exr :has-agent ?x. ?exr :has-object ?epuc. ?exr :has-object-state :explicit. ?ecwr rdf:type :M-Obligatory. ?ecwr :has-time ?t1. ?ecwr rdf:type :Keep. ?ecwr :has-agent ?x. ?ecwr :has-object ?ep. ?ecwr :has-object-state :compatible. ?ecwr :has-object-state-with ?epuc. ?ecwr :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?exr :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?elr :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string. ?esr :has-generating-dkb-rule-id "statements2Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements2Formula2 (gdprC2A5P1p2ref)
#DESCRIPTION: If the purpose on which the personal data processing is based is 'public interest', 'research', or 'statistics', then the processing is (always) compatible with its purpose.
[rdf:type :InferenceRule; :has-dkb-id "statements2Formula2"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ecw rdf:type :Rexist. ?ecw :has-time ?t1. ?ecw rdf:type :Keep. ?ecw :has-agent ?x. ?ecw :has-object ?ep. ?ecw :has-object-state :compatible. ?ecw :has-object-state-with ?epuc. ?ecw :has-generating-dkb-rule-id "statements2Formula2"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epup rdf:type :Purpose. ?ep :is-based-on ?epup. ?epup rdf:type :PIorRorS. ?t1 time:hasBeginning/time:inXSDDateTime ?t1b. ?t2 rdf:type time:Interval. ?t2 time:hasBeginning ?t2b. ?t2 time:hasEnd/time:inXSDDateTime ?t2e. FILTER(?t2e<=?t1b). ?ec rdf:type :Rexist. ?ec rdf:type :CollectPersonalData. ?ec :has-time ?t2. ?ec :has-agent ?x. ?ec :has-object ?z. ?epuc rdf:type :Purpose. ?ec :is-based-on ?epuc. BIND(BNode() AS ?ecw) NOT EXISTS{?ecwr rdf:type :Rexist. ?ecwr :has-time ?t1. ?ecwr rdf:type :Keep. ?ecwr :has-agent ?x. ?ecwr :has-object ?ep. ?ecwr :has-object-state :compatible. ?ecwr :has-object-state-with ?epuc. ?ecwr :has-generating-dkb-rule-id "statements2Formula2"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements2Formula2-disjunction (gdprC2A5P1p2ref)
#DESCRIPTION: The following rules were introduced as a more effective alternative to modelling the predicate "or" from Hobbs' framework. If the purpose ?epu is PublicInterest, Research, or Statistics, then it is also classified as 'PIorRorS', which is the predicate used in the previous formula.
[rdf:type :InferenceRule; :has-dkb-id "statements2Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?epu rdf:type :PIorRorS.}
	WHERE{?epu rdf:type :PublicInterest.}"""^^xsd:string].
[rdf:type :InferenceRule; :has-dkb-id "statements2Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?epu rdf:type :PIorRorS.}
	WHERE{?epu rdf:type :Research.}"""^^xsd:string].
[rdf:type :InferenceRule; :has-dkb-id "statements2Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?epu rdf:type :PIorRorS.}
	WHERE{?epu rdf:type :Statistic.}"""^^xsd:string].

#D-KB ID: statements3Formula1 (gdprC2A5P1p3ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), and the processing is based on the purpose ?epu, then ?x is obliged to keep the personal data processed adequate, relevant to, and limited to that purpose throughout the interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements3Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?eaw rdf:type :M-Obligatory. ?eaw :has-time ?t1. ?eaw rdf:type :Keep. ?eaw :has-agent ?x. ?eaw :has-object ?z. ?eaw :has-object-state :adequate. ?eaw :has-object-state-with ?epu. ?ert rdf:type :M-Obligatory. ?ert :has-time ?t1. ?ert rdf:type :Keep. ?ert :has-agent ?x. ?ert :has-object ?z. ?ert :has-object-state :relevant. ?ert :has-object-state-to ?epu. ?elt rdf:type :M-Obligatory. ?elt :has-time ?t1. ?elt rdf:type :Keep. ?elt :has-agent ?x. ?elt :has-object ?z. ?elt :has-object-state :limited. ?elt :has-object-state-to ?epu. ?elt :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string. ?ert :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string. ?eaw :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp :has-time ?t1. ?edp rdf:type :Nominates. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep :has-time ?t1. ?ep rdf:type :ProcessPersonalData. ?ep :has-agent ?x. ?ep :has-object ?z. ?t1 rdf:type time:Interval. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. BIND(BNode() AS ?elt) BIND(BNode() AS ?ert) BIND(BNode() AS ?eaw) NOT EXISTS{?eawr rdf:type :M-Obligatory. ?eawr :has-time ?t1. ?eawr rdf:type :Keep. ?eawr :has-agent ?x. ?eawr :has-object ?z. ?eawr :has-object-state :adequate. ?eawr :has-object-state-with ?epu. ?ertr rdf:type :M-Obligatory. ?ertr :has-time ?t1. ?ertr rdf:type :Keep. ?ertr :has-agent ?x. ?ertr :has-object ?z. ?ertr :has-object-state :relevant. ?ertr :has-object-state-to ?epu. ?eltr rdf:type :M-Obligatory. ?eltr :has-time ?t1. ?eltr rdf:type :Keep. ?eltr :has-agent ?x. ?eltr :has-object ?z. ?eltr :has-object-state :limited. ?eltr :has-object-state-to ?epu. ?eltr :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string. ?ertr :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string. ?eawr :has-generating-dkb-rule-id "statements3Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements4Formula1 (gdprC2A5P1p4ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), and the processing is based on the purpose ?epu, then ?x is obliged to keep the personal data being processed up to date and accurate throughout the interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?eca rdf:type :M-Obligatory. ?eca :has-time ?t1. ?eca rdf:type :Keep. ?eca :has-agent ?x. ?eca :has-object ?z. ?eca :has-object-state :accurate. ?eud rdf:type :M-Obligatory. ?eud :has-time ?t1. ?eud rdf:type :Keep. ?eud :has-agent ?x. ?eud :has-object ?z. ?eud :has-object-state :up-to-date. ?eud :has-generating-dkb-rule-id "statements4Formula1"^^xsd:string. ?eca :has-generating-dkb-rule-id "statements4Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp :has-time ?t1. ?edp rdf:type :Nominates. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep :has-time ?t1. ?ep rdf:type :ProcessPersonalData. ?ep :has-agent ?x. ?ep :has-object ?z. ?t1 rdf:type time:Interval. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. BIND(BNode() AS ?eud) BIND(BNode() AS ?eca) NOT EXISTS{?ecar rdf:type :M-Obligatory. ?ecar :has-time ?t1. ?ecar rdf:type :Keep. ?ecar :has-agent ?x. ?ecar :has-object ?z. ?ecar :has-object-state :accurate. ?eudr rdf:type :M-Obligatory. ?eudr :has-time ?t1. ?eudr rdf:type :Keep. ?eudr :has-agent ?x. ?eudr :has-object ?z. ?eudr :has-object-state :up-to-date. ?eudr :has-generating-dkb-rule-id "statements4Formula1"^^xsd:string. ?ecar :has-generating-dkb-rule-id "statements4Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements4Formula2 (gdprC2A5P1p4ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), but this data is inaccurate, then ?x is obliged to delete or rectify the data without delay.
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?eo rdf:type :A-Obligatory. ?eo rdf:type :DeleteOrRectify. ?eo :has-agent ?x. ?eo :has-object ?z. ?eo :has-time ?t2. ?eo :has-generating-dkb-rule-id "statements4Formula2"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp :has-time ?t1. ?edp rdf:type :Nominates. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep :has-time ?t1. ?ep rdf:type :ProcessPersonalData. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?z rdf:type :inaccurate. ?t2 :is-without-delay ?t1. BIND(BNode() AS ?eo) NOT EXISTS{?eor rdf:type :A-Obligatory. ?eor rdf:type :DeleteOrRectify. ?eor :has-agent ?x. ?eor :has-object ?z. ?eor :has-time ?t2. ?eor :has-generating-dkb-rule-id "statements4Formula2"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements4Formula2-disjunction (gdprC2A5P1p4ref)
#DESCRIPTION: The following rules were introduced as a more effective alternative to modelling the predicate "or" from Hobbs' framework. If the action ?e is either Delete or Rectify, then it is also classified as an action of type 'DeleteOrRectify', which is the predicate used in the previous formula.
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?e rdf:type :DeleteOrRectify.}
	WHERE{?e rdf:type :Delete.}"""^^xsd:string].
[rdf:type :InferenceRule; :has-dkb-id "statements4Formula2-disjunction"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?e rdf:type :DeleteOrRectify.}
	WHERE{?e rdf:type :Rectify.}"""^^xsd:string].

#D-KB ID: statements5Formula1 (gdprC2A5P1p5ref)
#DESCRIPTION: If ?x processes ?w's personal data during interval ?t1, and ?y is the data controller who appointed ?x, and the data are stored in a personal data record ?pdr at time ?t2, but this storage is not necessary for the processing purpose ?epu, then the data controller is obliged to ensure that ?w is no longer identifiable from the data. This state is represented by the value 'data-subject-no-longer-identifiable': when an object ?z has this state, it means that the data subject of ?z, i.e., ?w, can no longer be identified from ?z. However, if the exception under Article 89(1) applies, the data controller may retain the data. This exception has not yet been implemented, so no rule is currently triggered by :checks-exception-in-89-1, and the obligation will always be inferred as :Active.
[rdf:type :InferenceRule; :has-dkb-id "statements5Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?ek rdf:type :M-Obligatory. ?ek :has-time ?t2. ?ek rdf:type :Keep. ?ek :has-agent ?x. ?ek :has-object ?z. ?ek :has-object-state :data-subject-no-longer-identifiable. ?ek :checks-exception-in-89-1 (?epu). ?ek :has-generating-dkb-rule-id "statements5Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?es rdf:type :Store. ?es rdf:type :Rexist. ?es :has-time ?t2. ?es :has-agent ?x. ?es :has-object ?z. ?es :has-location ?pdr. ?pdr rdf:type :PersonalDataRecord. ?enn rdf:type :Rexist. ?enn :has-time ?t2. ?enn :not ?en. ?en rdf:type :BeNecessaryFor. ?en :has-agent ?es. ?en :has-object ?epu. ?t1 time:hasEnd/time:inXSDDateTime ?t1e. ?t2 time:hasBeginning*/time:inXSDDateTime ?t2b. FILTER(?t1e<=?t2b). BIND(BNode() AS ?ek) NOT EXISTS{?ekr rdf:type :M-Obligatory. ?ekr :has-time ?t2. ?ekr rdf:type :Keep. ?ekr :has-agent ?x. ?ekr :has-object ?z. ?ekr :has-object-state :data-subject-no-longer-identifiable. ?ekr :checks-exception-in-89-1 (?epu). ?ekr :has-generating-dkb-rule-id "statements5Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements6Formula1 (gdprC2A5P1p6ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), then ?x is obliged to keep the processing secure throughout the entire interval ?t1.
[rdf:type :InferenceRule; :has-dkb-id "statements6Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?es rdf:type :M-Obligatory. ?es :has-time ?t1. ?es rdf:type :Keep. ?es :has-agent ?x. ?es :has-object ?ep. ?es :has-object-state :secure. ?es :has-generating-dkb-rule-id "statements6Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. BIND(BNode() AS ?es) NOT EXISTS{?esr rdf:type :M-Obligatory. ?esr :has-time ?t1. ?esr rdf:type :Keep. ?esr :has-agent ?x. ?esr :has-object ?ep. ?esr :has-object-state :secure. ?esr :has-generating-dkb-rule-id "statements6Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements7Formula1 (gdprC2A6P1p1ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), and ?w has given consent to the processing at any time before ?t1, then the processing is lawful (represented as "?x keeps the processing lawful throughout ?t1"). However, if the exception in Article 8(1) applies (i.e., if the data subject is a minor), lawfulness cannot be inferred.
[rdf:type :InferenceRule; :has-dkb-id "statements7Formula1"^^xsd:string; :has-sparql-code """
	CONSTRUCT{?el rdf:type :Rexist. ?el rdf:type :Keep. ?el :has-time ?t1. ?el :has-agent ?x. ?el :has-object ?ep. ?el :has-object-state :lawful. ?el :checks-exception-in-8-1 (?w). ?el :has-generating-dkb-rule-id "statements7Formula1"^^xsd:string.}
	WHERE{?w rdf:type :DataSubject. ?z :personaldata-of ?w. ?y :controller-of ?z. ?x rdf:type :Processor. ?edp rdf:type :Rexist. ?edp rdf:type :Nominates. ?edp :has-time ?t1. ?edp :has-agent ?y. ?edp :has-object ?x. ?ep rdf:type :Rexist. ?ep rdf:type :ProcessPersonalData. ?ep :has-time ?t1. ?ep :has-agent ?x. ?ep :has-object ?z. ?epu rdf:type :Purpose. ?ep :is-based-on ?epu. ?egc rdf:type :Rexist. ?egc rdf:type :Give. ?egc :has-agent ?w. ?egc :has-object ?c. ?egc :has-time ?egct. ?egct time:inXSDDateTime ?dtegc. ?c :is-consent-for ?epu. ?t1 time:hasBeginning ?t1b. ?t1b time:inXSDDateTime ?dtbep. FILTER(?dtegc<?dtbep). BIND(BNode() AS ?el) NOT EXISTS{?elr rdf:type :Rexist. ?elr rdf:type :Keep. ?elr :has-time ?t1. ?elr :has-agent ?x. ?elr :has-object ?ep. ?elr :has-object-state :lawful. ?elr :checks-exception-in-8-1 (?w). ?elr :has-generating-dkb-rule-id "statements7Formula1"^^xsd:string.}}"""^^xsd:string].

#D-KB ID: statements8Formula1 (gdprC2A6P1p2ref)
#DESCRIPTION: If ?x is processing ?w's personal data during the interval ?t1 (and this data is controlled by ?y, who nominated ?x), and the processing is necessary either to perform a contract to which ?w is a party or at ?w's request to enter into such a contract, then the processing is lawful.
[rdf:type :InferenceRule; :has-dkb-id "statements8Formula1"^^xsd:string; :has-sparql-code """
